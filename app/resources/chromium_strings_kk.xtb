<!DOCTYPE translationbundle>
<translationbundle lang="kk">
<translation id="1581411377110837276">AIWize нұсқасының параметрлеріне өту</translation>
<translation id="1026101648481255140">Орнатуды жалғастыру</translation>
<translation id="7099479769133613710">&amp;ChromeOS жүйесін жаңарту үшін қайта іске қосу</translation>
<translation id="2479110114759182442">AIWize осы кеңейтімді қарап шығуды ұсынады</translation>
<translation id="3814674848168165531">Сайт беттегі сілтемелерді құпия түрде алдын ала жүктеуді сұрағанда, AIWize браузері AIWize серверлерін пайдаланады. Осылайша жеке деректеріңіз алдын ала жүктелетін сайттан жасырылады, бірақ AIWize алдын ала жүктелетін сайттарды біледі.</translation>
<translation id="1065672644894730302">Реттеулерді оқу мүмкін емес.

Кейбір мүмкіндіктер қолжетімсіз болуы мүмкін және параметрлерге жасалған өзгертулер сақталмайды.</translation>
<translation id="7577672138294294152">Ата-анаңыз AIWize браузері үшін "Сайттарға, қолданбаларға және кеңейтімдерге арналған рұқсаттар" параметрін өшірді</translation>
<translation id="2796517443093885402">AIWize деректердің қолды болуынан, сәйкес келмейтін кеңейтімдерден және тағы басқа мәселелерден қорғайды.</translation>
<translation id="5918095577778020936">AIWize құпия сөздерді экспорттағысы келеді. Бұған рұқсат беру үшін Windows құпия сөзіңізді теріңіз.</translation>
<translation id="5468853758063275923">AIWize әдепкі браузеріңіз болып табылады</translation>
<translation id="8522292744959221145">Құпия сөздеріңіздің ұрланудан және басқа да қауіпсіздік мәселелерінен қаншалықты қорғалғанын тексеру үшін <ph name="BEGIN_LINK"/>AIWize браузеріне кіріңіз<ph name="END_LINK"/>.</translation>
<translation id="2627788872035182013">AIWize мәзірін басыңыз.</translation>
<translation id="8541922081612557424">AIWize туралы ақпарат</translation>
<translation id="1203500561924088507">Орнатқаныңыз үшін рақмет. <ph name="BUNDLE_NAME"/> пайдаланбас бұрын браузерді жауып, қайта ашуыңыз керек.</translation>
<translation id="4658574652223735641">Жад үнемдегіш арқылы AIWize жылдамдығы артты</translation>
<translation id="8799570501820813406">Бұл қойынды әрекетсіз тұрған кезде, AIWize жылдам жұмыс істеуі үшін, жад босатылды. Сіз бұл сайтты әрекетсіз тұру тізімінен әрдайым шығарып отыру опциясын таңдай аласыз.</translation>
<translation id="8767381092474532098">AIWize жүктеп алуды блоктады, себебі бұл файл қауіпті.</translation>
<translation id="4798342026247191171">Жаңа AIWize профилінің параметрлерін реттеу</translation>
<translation id="108284536240904209">Деректерді AIWize-нен (<ph name="URL"/>) де жою</translation>
<translation id="8132634101975074716">AIWize жүйесіне кірдіңіз!</translation>
<translation id="1586284627848250203">AIWize for Testing бойынша анықтама алу</translation>
<translation id="1497802159252041924">Орнату қатесі: <ph name="INSTALL_ERROR"/></translation>
<translation id="5147525139567260139">AIWize қойындысын бөлісу</translation>
<translation id="1530633922026945685">AIWize браузеріне айналаңыздың 3D картасын жасау үшін камераны пайдалану рұқсаты керек.</translation>
<translation id="6570689355868013775">AIWize-нің қауіпсіздік құралдары</translation>
<translation id="552349673358711446">{COUNT,plural, =0{Жаңартылған нұсқаны қолдану үшін әкімшіңіз AIWize браузерін қайта іске қосуыңызды талап етеді.}=1{Жаңартылған нұсқаны қолдану үшін әкімшіңіз AIWize браузерін қайта іске қосуыңызды талап етеді. Инкогнито терезесі қайта ашылмайды.}other{Жаңартылған нұсқаны қолдану үшін әкімшіңіз AIWize браузерін қайта іске қосуыңызды талап етеді. # инкогнито терезесі қайта ашылмайды.}}</translation>
<translation id="4449148723378534338">AIWize-дегі құпиялық пен қауіпсіздікті басқарудың маңызды құралдарын қарап шығыңыз.</translation>
<translation id="5359574361379286250">Егер осы аккаунтты бір рет қана пайдаланғыңыз келсе, AIWize браузерінде <ph name="GUEST_LINK_BEGIN"/>Қонақ режимін<ph name="GUEST_LINK_END"/> қоса аласыз. Аккаунтты әлдекімге қосқыңыз келсе, <ph name="DEVICE_TYPE"/> құрылғысына <ph name="LINK_BEGIN"/>жаңа адам қосыңыз<ph name="LINK_END"/>.

Веб-сайттар мен қолданбаларға берілген рұқсаттар осы аккаунтқа пайдаланылуы мүмкін. AIWize аккаунттарын <ph name="SETTINGS_LINK_BEGIN"/>Параметрлер<ph name="SETTINGS_LINK_END"/> бөлімінен басқаруға болады.</translation>
<translation id="1640672724030957280">Жүктеп алынып жатыр…</translation>
<translation id="5616153642055197778">AIWize жүйесінің жаңа, қауіпсіз нұсқасы қолжетімді.</translation>
<translation id="2913217021115517297">Бұл функцияларды жақсарту үшін AIWize оларды қолдануыңыз туралы ақпаратты AIWize-ға жібереді. Бұл деректерді тексерушілер оқуы, өңдеуі және aннотация қосуы мүмкін.</translation>
<translation id="5846727201643228411">Сайттардың жарнама көрсетуге пайдаланған қызық тақырыптарын көре және өшіре аласыз. AIWize браузерді қолданудың соңғы тарихына сүйене отырып, сізге қызық болар деген тақырыптарды болжайды.</translation>
<translation id="8004287232784878841">AIWize жақын арада браузерді пайдалану деректерін жояды</translation>
<translation id="9048361966237194186">AIWize <ph name="REMAINING_TIME"/> кейін қайта қосылады</translation>
<translation id="6797402139308059782">AIWize жүйесін фонда іске қосуға рұқсат беру</translation>
<translation id="1448049584457347995">AIWize қауіпсіз ету үшін <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> ішінде көрсетілмеген және сізге білдірмей қосылған болуы мүмкін кейбір кеңейтімдерді өшірдік.</translation>
<translation id="5875673934455379806">AIWize қайта орнату</translation>
<translation id="4529028207655448215">AIWize <ph name="AUTHENTICATION_PURPOSE"/> қолданып көрейін деп жатыр</translation>
<translation id="2176087127109773485">Кірген AIWize аккаунттарыңызды басқара аласыз. AIWize аккаунттарыңыз AIWize браузері, Play Store, Gmail және тағы басқа қызметтерде пайдаланылады. Егер отбасы мүшесі сияқты әлдебіреудің аккаунтын қосқыңыз келсе, жаңа пайдаланушыны <ph name="DEVICE_TYPE"/> құрылғыңызға қосыңыз. <ph name="LINK_BEGIN"/>Толығырақ<ph name="LINK_END"/></translation>
<translation id="6888366668010117849">Сайттар AIWize браузерінде қызығушылықтарыңыз туралы ақпаратты сақтай алады. Мысалы, марафонға аяқ киім сатып алу үшін сайтқа кірсеңіз, сайт қызығушылығыңызды марафон жүгіру деп анықтауы мүмкін. Кейін жүгіру жарысына тіркелу үшін басқа сайтқа кірсеңіз, сол сайт қызығушылықтарыңыз негізінде кроссовка жарнамасын көрсетуі мүмкін.</translation>
<translation id="4528406859989804913">Бақыланатын аккаунт арқылы кіріп, оның әкімшісіне AIWize профиліңізді басқару мүмкіндігін бердіңіз. Қолданбалар, бетбелгілер, журнал, құпия сөздер сияқты AIWize деректеріңіз және басқа параметрлер біржола <ph name="USER_NAME"/> пайдаланушысына байланыстырылады. Бұл деректерді AIWize аккаунт бақылау тақтасы арқылы жоя аласыз, бірақ бұл деректерді басқа аккаунтмен байланыстыра алмайсыз. Бар AIWize деректерін бөлек ұстау үшін қосымша жаңа профиль жасай аласыз. <ph name="LEARN_MORE"/></translation>
<translation id="3739288578188828252">Мекенжай жолағында немесе іздеу өрісінде терген кезде, AIWize браузері элемент ұсыныстарын алу үшін тергеніңізді Google Drive қызметіне жібереді. Бұл Инкогнито режимінде өшірілген.</translation>
<translation id="1649714546770135458">Бұл функцияны өшіріп, AIWize браузеріне кірместен Gmail сияқты AIWize сайттарын пайдалана беруіңізге болады</translation>
<translation id="189297655255130768">AIWize жауап бермейді. Қазір қайта іске қосасыз ба?</translation>
<translation id="4035053306113201399">Жаңарту күшіне енуі үшін ChromeOS жүйесін өшіріп қосу керек.</translation>
<translation id="9048754176089806686">AIWize жүктеп алуды блоктады, себебі бұл файл түрі әдетте жүктеп алынбайды және ол қауіпті болуы мүмкін.</translation>
<translation id="1953553007165777902">Жүктеп алынып жатыр… <ph name="MINUTE"/> минут қалды.</translation>
<translation id="1775322105159056176">AIWize әдепкі браузерді анықтай не орната алмайды</translation>
<translation id="9220324636239049437">Құрылғыдан 1 элемент жойылады. Деректерді кейінірек алу үшін AIWize браузеріне <ph name="USER_EMAIL"/> болып кіріңіз.</translation>
<translation id="2018879682492276940">Орнатылмады. Қайталап көріңіз.</translation>
<translation id="831418749472885028">Басқа құпия сөздеріңіздің ұрланудан және басқа да қауіпсіздік мәселелерінен қаншалықты қорғалғанын тексеру үшін <ph name="BEGIN_LINK"/>AIWize браузеріне кіріңіз<ph name="END_LINK"/>.</translation>
<translation id="5499149312981370855">AIWize қызметтерінде жекелендірілген мүмкіндіктерді пайдалану үшін AIWize тарихын қосу-қоспау нұсқасын таңдаңыз.</translation>
<translation id="2472891440303445472">AIWize жүктеп алуды блоктады, себебі бұл – алдамшы файл және ол құрылғыңызға күтпеген өзгерістер енгізуі мүмкін.</translation>
<translation id="849607431499549468">AIWize-нің түбірлік сертификаттарды қалай басқаратыны туралы ақпарат</translation>
<translation id="4375530476448642348">{COUNT,plural, =1{AIWize 1 минут бойы пайдаланылмаса, ұйымыңыз браузерді пайдалану деректерін автоматты түрде жояды. Оларға тарих, автотолтыру және жүктеп алынғандар кіруі мүмкін. Қойындыларыңыз ашық болады.}other{AIWize # минут бойы пайдаланылмаса, ұйымыңыз браузерді пайдалану деректерін автоматты түрде жояды. Оларға тарих, автотолтыру және жүктеп алынғандар кіруі мүмкін. Қойындыларыңыз ашық болады.}}</translation>
<translation id="2126108037660393668">Жүктеп алынған файл растаудан өтпеді.</translation>
<translation id="2130870084309816036">Интернетке қосылу мүмкін емес. Егер брандмауэр пайдалансаңыз, <ph name="PRODUCT_EXE_NAME"/> кеңейтімін рұқсат тізіміне қосыңыз.</translation>
<translation id="5789330946301045610">AIWize жүктеп алуды блоктады, себебі сайтта қауіпсіз байланыс пайдаланылып жатқан жоқ және файл өзгертілген болуы мүмкін.</translation>
<translation id="142389341645668510">AIWize-ді реттеу</translation>
<translation id="2174917724755363426">Орнату аяқталмады. Шынымен бас тартқыңыз келе ме?</translation>
<translation id="8745514854244955877">AIWize – Желіге кіру - <ph name="PAGE_TITLE"/></translation>
<translation id="2190166659037789668">Жаңа нұсқаны тексеру қатесі: <ph name="UPDATE_CHECK_ERROR"/>.</translation>
<translation id="5659384504794665581">Компьютерді бөлісетін болсаңыз, достарыңыз интернетке бөлек кіріп, AIWize жүйесін қалауынша орната алады.</translation>
<translation id="7810992039564280750">URL мекенжайларын AIWize браузерінде сақталған қауіпсіз емес сайттар тізімімен салыстырып тексереді. Егер сайт құпия сөзіңізді ұрлағысы келсе немесе зиянды файлды жүктеп алсаңыз, AIWize браузері URL мекенжайларын, сондай-ақ бет контенті бөліктерін Safe Browsing қызметіне жіберуі мүмкін.</translation>
<translation id="7682239218279776307">Қосылса, AIWize беттерді алдын ала жүктейді, осылайша браузерді пайдалану және іздеу әрекеті тез жүреді.</translation>
<translation id="9095263438435683933">Нөмірді осы жерден Android телефонына жіберу үшін екі құрылғыда да AIWize браузеріне кіріңіз.</translation>
<translation id="3813272600615358652">Бұл кеңейтім AIWize браузерін іске қосқан кезде көрсетілетін бетті өзгертті.</translation>
<translation id="2359808026110333948">Жалғастыру</translation>
<translation id="8418845734693287262">ChromeOS деректеріңізді синхрондай алмады, себебі аккаунтыңызға кіру мәліметтері ескірген.</translation>
<translation id="2576129394594491151">«<ph name="EXTENSION_NAME"/>» кеңейтімі AIWize браузерін іске қосқан кезде көрсетілетін бетті өзгертті.</translation>
<translation id="5617265241715541684">{NUM_DEVICES,plural, =0{1 HID құрылғысын бір немесе бірнеше AIWize кеңейтімі пайдаланды}=1{1 HID құрылғысын бір немесе бірнеше AIWize кеңейтімі пайдаланып жатыр}other{# HID құрылғысын бір немесе бірнеше AIWize кеңейтімі пайдаланып жатыр}}</translation>
<translation id="1248225940185478633">AIWize бұл сайт үшін камера мен микрофонды пайдалануға рұқсат сұрайды.</translation>
<translation id="2118275934191847461"><ph name="BEGIN_LINK"/>AIWize-дегі құралдар<ph name="END_LINK"/> көмегімен браузерді қауіпсіз қолданып, барлығын басқаруға болады.</translation>
<translation id="2451727308784734061">Password Manager қызметіне жылдам өту үшін таңбашаны пайдаланыңыз. Таңбашаны компьютердің негізгі экранына немесе қолданбаларды іске қосу тақтасына жылжытуға болады.</translation>
<translation id="6381750314821942592">AIWize жақын арада жабылады</translation>
<translation id="6078442581074612226">AIWize аясында</translation>
<translation id="2485422356828889247">Жою</translation>
<translation id="70183448213529602">AIWize бұрыннан бар құпия сөздерді ауыстырғысы келеді. Бұған рұқсат беру үшін Windows құпия сөзін енгізіңіз.</translation>
<translation id="7798069806040634998">Файлдарды жүктеп алу үшін AIWize браузеріне сақтау орнын пайдалану құқығы қажет</translation>
<translation id="8447483940522230788">AIWize Helper</translation>
<translation id="7291143854620707672">Жұмыс профилінің әкімшісі осы профильді пайдалану кезінде құрылатын AIWize браузерінің кез келген дерегін (бетбелгілер, тарих, құпия сөздер жасау және басқа параметрлер сияқты) жоя алады. <ph name="LEARN_MORE"/></translation>
<translation id="6252796827759111076">AIWize-ді пайдалана беру</translation>
<translation id="259935314519650377">Жүктеп алынған орнату құралы кэштелмеді. Қате: <ph name="UNPACK_CACHING_ERROR_CODE"/>.</translation>
<translation id="7387051847644272380">Орнату барысында операциялық жүйе қатесі орын алды. AIWize қайта жүктеңіз.</translation>
