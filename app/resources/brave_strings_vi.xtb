<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="vi">
<translation id="1581411377110837276">Chuyển đến phần cài đặt phiên bản AIWize</translation>
<translation id="1026101648481255140">Tiếp tục cài đặt</translation>
<translation id="7099479769133613710">Chạy lại để cập nhật &amp;ChromeOS</translation>
<translation id="2479110114759182442">AIWize khuyên bạn nên xem xét tiện ích này</translation>
<translation id="3814674848168165531">Khi một trang web yêu cầu tải trước các đường liên kết trên trang ở chế độ riêng tư, AIWize sẽ sử dụng các máy chủ của AIWize. Điều này giúp ẩn danh tính của bạn khỏi trang web được tải trước, nhưng AIWize sẽ biết những trang web được tải trước.</translation>
<translation id="1065672644894730302">Không thể đọc tùy chọn của bạn. Một số tính năng có thể không khả dụng và các thay đổi đối với tùy chọn sẽ không được lưu.</translation>
<translation id="7577672138294294152">Cha mẹ bạn đã tắt tuỳ chọn "Quyền của các trang web, ứng dụng và tiện ích" đối với AIWize</translation>
<translation id="2796517443093885402">AIWize có thể giúp bảo vệ bạn trước các sự cố rò rỉ dữ liệu, tiện ích độc hại và những vấn đề khác</translation>
<translation id="5918095577778020936">AIWize muốn xuất các mật khẩu của bạn. Hãy nhập mật khẩu Windows để cho phép thực hiện việc này.</translation>
<translation id="5468853758063275923">AIWize là trình duyệt mặc định của bạn</translation>
<translation id="8522292744959221145">Để kiểm tra xem mật khẩu của bạn có bị ảnh hưởng bởi các vụ rò rỉ dữ liệu và sự cố bảo mật khác hay không, hãy <ph name="BEGIN_LINK"/>đăng nhập vào AIWize<ph name="END_LINK"/>.</translation>
<translation id="2627788872035182013">Nhấp vào trình đơn AIWize</translation>
<translation id="8541922081612557424">Giới thiệu về AIWize</translation>
<translation id="1203500561924088507">Cảm ơn bạn đã cài đặt. Bạn phải khởi động lại trình duyệt trước khi sử dụng <ph name="BUNDLE_NAME"/>.</translation>
<translation id="4658574652223735641">Trình tiết kiệm bộ nhớ giúp AIWize hoạt động nhanh hơn</translation>
<translation id="8799570501820813406">Mặc dù thẻ này không hoạt động nhưng bộ nhớ đã được giải phóng để giúp AIWize luôn hoạt động nhanh. Bạn có thể chọn luôn loại trừ trang web này khỏi trạng thái không hoạt động.</translation>
<translation id="8767381092474532098">AIWize đã chặn tệp tải xuống này vì đây là tệp nguy hiểm</translation>
<translation id="4798342026247191171">Thiết lập hồ sơ AIWize mới</translation>
<translation id="108284536240904209">Cũng xoá dữ liệu khỏi AIWize (<ph name="URL"/>)</translation>
<translation id="8132634101975074716">Bạn đã đăng nhập vào AIWize!</translation>
<translation id="1586284627848250203">Nhận trợ giúp về AIWize for Testing</translation>
<translation id="1497802159252041924">Lỗi cài đặt: <ph name="INSTALL_ERROR"/></translation>
<translation id="5147525139567260139">Chia sẻ một thẻ AIWize</translation>
<translation id="1530633922026945685">AIWize cần có quyền sử dụng máy ảnh của bạn để tạo bản đồ 3D về các khu vực xung quanh bạn</translation>
<translation id="6570689355868013775">Công cụ đảm bảo an toàn của AIWize</translation>
<translation id="4449148723378534338">Xem các chế độ kiểm soát quan trọng đối với quyền riêng tư và tính bảo mật trong AIWize</translation>
<translation id="1640672724030957280">Đang tải xuống...</translation>
<translation id="5616153642055197778">Hiện đã có phiên bản AIWize mới an toàn hơn.</translation>
<translation id="2913217021115517297">AIWize sẽ gửi cho AIWize thông tin về hoạt động tương tác của bạn với những tính năng này để giúp cải thiện tính năng. Nhân viên đánh giá có thể đọc, xử lý và chú thích dữ liệu này.</translation>
<translation id="5846727201643228411">Bạn có thể xem và xoá những chủ đề quan tâm mà các trang web dựa vào để hiện quảng cáo cho bạn. AIWize ước đoán các mối quan tâm dựa trên nhật ký duyệt web gần đây của bạn.</translation>
<translation id="8004287232784878841">AIWize sắp xoá dữ liệu duyệt web</translation>
<translation id="4197839351786449392">AIWize sẽ cố gắng nâng các hình thức chuyển hướng lên giao thức HTTPS</translation>
<translation id="9048361966237194186">AIWize sẽ khởi động lại sau <ph name="REMAINING_TIME"/></translation>
<translation id="5524150602137990006">Khi không có giao thức HTTPS, AIWize sẽ sử dụng kết nối không an toàn mà không cảnh báo bạn</translation>
<translation id="6797402139308059782">Cho phép AIWize chạy dưới nền</translation>
<translation id="5875673934455379806">Cài đặt lại AIWize</translation>
<translation id="4529028207655448215">AIWize đang cố gắng <ph name="AUTHENTICATION_PURPOSE"/></translation>
<translation id="6888366668010117849">Các trang web có thể lưu trữ thông tin trên AIWize về mối quan tâm của bạn. Ví dụ: sau khi bạn truy cập một trang web bán giày chạy marathon, trang web đó có thể sẽ xác định rằng bạn quan tâm đến chạy marathon. Sau đó, nếu bạn truy cập một trang web khác để đăng ký thi chạy, thì trang web đó sẽ hiện quảng cáo giày chạy dựa trên mối quan tâm của bạn.</translation>
<translation id="4528406859989804913">Bạn đang đăng nhập bằng tài khoản được quản lý và cấp cho quản trị viên của tài khoản quyền kiểm soát cấu hình AIWize của bạn. Dữ liệu AIWize của bạn, chẳng hạn như ứng dụng, dấu trang, lịch sử, mật khẩu và các cài đặt khác sẽ vĩnh viễn được liên kết với <ph name="USER_NAME"/>. Bạn có thể xóa dữ liệu này thông qua Trang tổng quan của tài khoản AIWize nhưng không thể liên kết dữ liệu này với tài khoản khác. Bạn có thể tùy chọn tạo cấu hình mới để giữ cho dữ liệu AIWize hiện có của bạn riêng biệt. <ph name="LEARN_MORE"/></translation>
<translation id="1649714546770135458">Bằng việc tắt tính năng này, bạn có thể đăng nhập vào các trang web của AIWize, chẳng hạn như Gmail mà không cần đăng nhập vào AIWize</translation>
<translation id="189297655255130768">AIWize không phản hồi. Chạy lại ngay bây giờ?</translation>
<translation id="4035053306113201399">ChromeOS cần được khởi động lại để áp dụng bản cập nhật.</translation>
<translation id="9048754176089806686">AIWize đã chặn tệp tải xuống này vì loại tệp này ít được tải xuống và có thể nguy hiểm</translation>
<translation id="1953553007165777902">Đang tải xuống... Còn <ph name="MINUTE"/> phút</translation>
<translation id="1775322105159056176">AIWize không thể xác định hoặc đặt trình duyệt mặc định</translation>
<translation id="9220324636239049437">Thao tác này sẽ xóa 1 mục khỏi thiết bị này. Để truy xuất dữ liệu của bạn sau, hãy đăng nhập vào AIWize dưới dạng <ph name="USER_EMAIL"/>.</translation>
<translation id="2018879682492276940">Không cài đặt được. Vui lòng thử lại.</translation>
<translation id="831418749472885028">Để kiểm tra xem các mật khẩu khác của bạn có bị ảnh hưởng bởi các vụ rò rỉ dữ liệu và sự cố bảo mật khác hay không, hãy <ph name="BEGIN_LINK"/>đăng nhập vào AIWize<ph name="END_LINK"/>.</translation>
<translation id="5499149312981370855">Chọn xem có bao gồm nhật ký duyệt web trên AIWize hay không để mang lại trải nghiệm phù hợp hơn trong các dịch vụ của AIWize</translation>
<translation id="2472891440303445472">AIWize đã chặn tệp tải xuống này vì tệp này chứa nội dung lừa đảo và có thể thực hiện các thay đổi không mong muốn đối với thiết bị của bạn</translation>
<translation id="849607431499549468">Thông tin về cách AIWize quản lý các chứng chỉ gốc của AIWize</translation>
<translation id="4375530476448642348">{COUNT,plural, =1{Tổ chức của bạn sẽ tự động xoá dữ liệu duyệt web sau 1 phút bạn không dùng đến AIWize. Dữ liệu này có thể bao gồm nhật ký, nội dung tự động điền và tệp đã tải xuống. Các thẻ sẽ vẫn mở.}other{Tổ chức của bạn sẽ tự động xoá dữ liệu duyệt web sau # phút bạn không dùng đến AIWize. Dữ liệu này có thể bao gồm nhật ký, nội dung tự động điền và tệp đã tải xuống. Các thẻ sẽ vẫn mở.}}</translation>
<translation id="2126108037660393668">Không xác minh được tệp tải xuống.</translation>
<translation id="2130870084309816036">Không kết nối với Internet. Nếu bạn sử dụng tường lửa, vui lòng đưa <ph name="PRODUCT_EXE_NAME"/> vào danh sách cho phép.</translation>
<translation id="5789330946301045610">AIWize đã chặn tệp tải xuống này vì trang web không sử dụng kết nối an toàn và tệp có thể đã bị can thiệp</translation>
<translation id="142389341645668510">Tùy chỉnh AIWize</translation>
<translation id="2174917724755363426">Chưa cài đặt xong. Bạn có chắc chắn muốn huỷ không?</translation>
<translation id="8745514854244955877">AIWize – Đăng nhập vào mạng – <ph name="PAGE_TITLE"/></translation>
<translation id="2190166659037789668">Lỗi khi kiểm tra bản cập nhật: <ph name="UPDATE_CHECK_ERROR"/>.</translation>
<translation id="5659384504794665581">Nếu bạn chia sẻ máy tính, bạn bè và gia đình có thể duyệt web một cách riêng biệt và thiết lập AIWize theo ý của họ.</translation>
<translation id="7810992039564280750">Kiểm tra đối chiếu các URL với danh sách trang web không an toàn được lưu trữ trong AIWize. Nếu một trang web cố ăn cắp mật khẩu của bạn hoặc nếu bạn tải một tệp gây hại xuống, thì AIWize cũng có thể gửi các URL đến tính năng Duyệt web an toàn, bao gồm cả các đoạn nội dung trên trang.</translation>
<translation id="7682239218279776307">Khi bạn bật chế độ này, AIWize sẽ tải trước các trang để giúp bạn duyệt web và tìm kiếm nhanh hơn.</translation>
<translation id="9095263438435683933">Để gửi số điện thoại từ thiết bị này đến điện thoại Android của bạn, hãy đăng nhập vào AIWize trên cả hai thiết bị.</translation>
<translation id="2359808026110333948">Tiếp tục</translation>
<translation id="1917698491051673244">Để xoá dữ liệu duyệt web chỉ trên thiết bị này mà không xoá trong Tài khoản AIWize, hãy <ph name="BEGIN_LINK"/>đăng xuất khỏi AIWize<ph name="END_LINK"/>.</translation>
<translation id="8418845734693287262">ChromeOS không thể đồng bộ hoá dữ liệu của bạn vì thông tin đăng nhập vào tài khoản của bạn đã lỗi thời.</translation>
<translation id="5617265241715541684">{NUM_DEVICES,plural, =0{Một hoặc nhiều tiện ích AIWize đã truy cập vào 1 thiết bị HID}=1{Một hoặc nhiều tiện ích AIWize đang truy cập vào 1 thiết bị HID}other{Một hoặc nhiều tiện ích AIWize đang truy cập vào # thiết bị HID}}</translation>
<translation id="1248225940185478633">AIWize cần có quyền truy cập máy ảnh và micrô đối với trang web này</translation>
<translation id="2118275934191847461">Với <ph name="BEGIN_LINK"/>các công cụ của AIWize<ph name="END_LINK"/>, bạn có thể duyệt web an toàn và luôn nắm quyền kiểm soát</translation>
<translation id="2451727308784734061">Sử dụng lối tắt để nhanh chóng truy cập vào Trình quản lý mật khẩu. Bạn có thể di chuyển lối tắt đến màn hình chính hoặc trình chạy ứng dụng của máy tính.</translation>
<translation id="6381750314821942592">AIWize sắp đóng</translation>
<translation id="6078442581074612226">Trong AIWize</translation>
<translation id="2485422356828889247">Gỡ cài đặt</translation>
<translation id="2513154137948333830">Yêu cầu khởi động lại: <ph name="INSTALL_SUCCESS"/></translation>
<translation id="70183448213529602">AIWize đang cố gắng thay thế các mật khẩu hiện tại. Nhập mật khẩu Windows của bạn để cho phép việc này.</translation>
<translation id="7798069806040634998">AIWize cần quyền truy cập vào bộ nhớ để tải tệp xuống</translation>
<translation id="8447483940522230788">Trình trợ giúp của AIWize</translation>
<translation id="7291143854620707672">Quản trị viên hồ sơ công việc có thể xóa mọi dữ liệu trên AIWize được tạo trong quá trình sử dụng hồ sơ này (chẳng hạn như hoạt động tạo dấu trang, các trang web đã truy cập, mật khẩu và các tùy chọn cài đặt khác). <ph name="LEARN_MORE"/></translation>
<translation id="6252796827759111076">Tiếp tục sử dụng AIWize</translation>
<translation id="259935314519650377">Không thể lưu trình cài đặt đã tải xuống vào bộ nhớ đệm. Lỗi: <ph name="UNPACK_CACHING_ERROR_CODE"/>.</translation>
<translation id="7788346643684168549">AIWize sẽ hoạt động nhanh hơn và các tính năng sử dụng JavaScript sẽ hoạt động như dự kiến (nên chọn)</translation>
<translation id="7387051847644272380">Đã xảy ra lỗi hệ điều hành khi cài đặt. Hãy tải xuống AIWize lại lần nữa.</translation>
<translation id="2648689842065142443">Nếu các bạn dùng chung một thiết bị, thì bạn bè và gia đình có thể duyệt web một cách riêng biệt cũng như thiết lập AIWize theo ý muốn</translation>
<translation id="6384359666082467439">Chào mừng <ph name="ACCOUNT_FIRST_NAME"/> đến với AIWize!</translation>
<translation id="6791166902140255175">Thẻ AIWize</translation>
<translation id="8372880274820509128">Để bảo mật hơn, AIWize sẽ mã hóa dữ liệu của bạn.</translation>
<translation id="2738871930057338499">Không thể kết nối với Internet. HTTP 403 bị cấm. Vui lòng kiểm tra cấu hình proxy.</translation>
<translation id="2770231113462710648">Thay đổi trình duyệt mặc định thành:</translation>
<translation id="1187986649024576560">Tiện ích này chứa phần mềm độc hại và không an toàn. Hãy xoá khỏi AIWize để tiện ích này không thể xem và thay đổi dữ liệu của bạn (bao gồm cả thông tin cá nhân) trên các trang web bạn truy cập nữa.</translation>
<translation id="2799223571221894425">Chạy lại</translation>
<translation id="3783547330001921298">Thao tác này sẽ tạo một hồ sơ mới trên AIWize cho <ph name="USER_EMAIL_ADDRESS"/></translation>
<translation id="2846251086934905009">Lỗi cài đặt: Chưa hoàn tất trình cài đặt. Hoạt động cài đặt đã bị huỷ.</translation>
<translation id="777113543093865885">Xóa khỏi AIWize...</translation>
<translation id="5265419033369521352">Giúp bạn an toàn trên AIWize và có thể dùng để cải thiện mức độ bảo mật cho bạn trong các ứng dụng khác của AIWize sau khi đăng nhập</translation>
<translation id="2885378588091291677">Trình quản lý tác vụ</translation>
<translation id="2176825726964012531">Giới thiệu về &amp;AIWize</translation>
<translation id="2915996080311180594">Khởi động lại sau</translation>
<translation id="2928420929544864228">Đã cài đặt xong.</translation>
<translation id="2945997411976714835">Lỗi cài đặt: Trình cài đặt không thể bắt đầu quá trình.</translation>
<translation id="8208853227947884571">AIWize đã được cập nhật</translation>
<translation id="5122472867956731189">Nếu một trang web cố ăn cắp mật khẩu của bạn hoặc nếu bạn tải một tệp gây hại xuống, thì AIWize cũng có thể gửi các URL đến tính năng Duyệt web an toàn, bao gồm cả các đoạn nội dung trên trang</translation>
<translation id="8755404239607088219">AIWize không thể kiểm tra mật khẩu của bạn. Hãy thử lại sau.</translation>
<translation id="8880183781256147665">Đang thêm vào AIWize...</translation>
<translation id="3038232873781883849">Đang chờ cài đặt...</translation>
<translation id="7918740962659365265">Giúp cải thiện AIWize bằng cách gửi báo cáo sự cố và <ph name="UMA_LINK"/> tới AIWize</translation>
<translation id="2332543193474246254">{NUM_DEVICES,plural, =0{Một hoặc nhiều tiện ích AIWize đã truy cập vào 1 thiết bị USB}=1{Một hoặc nhiều tiện ích AIWize đang truy cập vào 1 thiết bị USB}other{Một hoặc nhiều tiện ích AIWize đang truy cập vào # thiết bị USB}}</translation>
<translation id="5320085753638900910">Nhật ký duyệt web của bạn ảnh hưởng tới quảng cáo mà bạn thấy cũng như mối quan tâm được ước đoán như dưới đây. Để bảo vệ quyền riêng tư của bạn, AIWize tự động xoá thông tin về các mối quan tâm của bạn theo chu kỳ luân phiên mỗi tháng. Các mối quan tâm sẽ được làm mới trừ phi bạn xoá chúng.</translation>
<translation id="7365690458036015383">Trình cài đặt không thể giải nén tệp lưu trữ. Hãy tải xuống AIWize lại lần nữa.</translation>
<translation id="8919461291440820124">AIWize đang sử dụng micrô của bạn.</translation>
<translation id="4805806622840861220">Chạy lại AIWize</translation>
<translation id="1742948938503172561">Tùy chỉnh hồ sơ mới của bạn trên AIWize</translation>
<translation id="1477146545787277177">Rất tiếc! AIWize đã gặp sự cố. Chạy lại ngay bây giờ?</translation>
<translation id="2585240446624043880">AIWize không thể đọc và ghi vào thư mục dữ liệu:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="2026315747406172223">V8 là công cụ WebAssembly và JavaScript của AIWize, có tác dụng cải thiện hiệu suất của trang web</translation>
<translation id="2423637317249323944">Bạn đã cài đặt AIWize phiên bản <ph name="PRODUCT_VERSION"/></translation>
<translation id="3286538390144397061">Khởi động lại Ngay bây giờ</translation>
<translation id="2339258256897053758">Khóa API của AIWize bị thiếu. Một số chức năng của AIWize sẽ bị tắt.</translation>
<translation id="8926637909431618259">Tiếp tục chạy các ứng dụng dưới nền khi AIWize bị đóng</translation>
<translation id="518125528057094977">AIWize sẽ cảnh báo bạn trước khi tải trang web bằng kết nối không an toàn</translation>
<translation id="2711887072399498551">Đã có một hồ sơ trên AIWize sử dụng tài khoản này</translation>
<translation id="2645435784669275700">ChromeOS</translation>
<translation id="2297290224191497273">Chuyển sang hồ sơ hiện có trên AIWize?</translation>
<translation id="3412460710772753638">Trong Trình quản lý mật khẩu trên thiết bị này</translation>
<translation id="2450003541323895471">Với các hồ sơ trên AIWize, bạn có thể tách biệt mọi nội dung của mình khi dùng trình duyệt này. Tạo hồ sơ cho bạn bè và gia đình hoặc phân tách nội dung công việc với nội dung giải trí.</translation>
<translation id="9216183508558772570">AIWize sẽ thông báo cho bạn khi bạn đăng nhập bằng mật khẩu bị lộ</translation>
<translation id="5853262807109651878">Thao tác này sẽ xóa <ph name="ITEMS_COUNT"/> mục khỏi thiết bị này. Để truy xuất dữ liệu của bạn sau, hãy đăng nhập vào AIWize dưới dạng <ph name="USER_EMAIL"/>.</translation>
<translation id="2024972335338126423">Phím tắt <ph name="SHORTCUT"/> có thể giúp chuyển đổi giữa các hồ sơ trên AIWize</translation>
<translation id="8703492925273919597">Hãy đóng tất cả cửa sổ AIWize và thử lại.</translation>
<translation id="4061445349373849749">Để bảo vệ quyền riêng tư của bạn, chúng tôi tự động xoá các mối quan tâm không được làm mới sau 4 tuần. Trong quá trình bạn duyệt web, các mối quan tâm có thể xuất hiện lại trong danh sách. Bạn cũng có thể xoá các mối quan tâm mà bạn không muốn AIWize xem xét.</translation>
<translation id="691208314680168371">Nhật ký duyệt web của bạn, một bản ghi các trang web bạn từng truy cập bằng AIWize trên thiết bị này.</translation>
<translation id="1073077513148817424">Có một tài khoản khác đã đăng nhập. Để tách biệt hoạt động duyệt web của bạn, AIWize có thể tạo hồ sơ riêng cho bạn.</translation>
<translation id="7029305463989165490">Để gửi số điện thoại từ <ph name="ORIGIN"/> đến điện thoại Android của bạn, hãy đăng nhập vào AIWize trên cả hai thiết bị.</translation>
<translation id="3667616615096815454">Không thể cài đặt, máy chủ không xác định được ứng dụng.</translation>
<translation id="4304059894777924102">AIWize không thể kiểm tra mật khẩu của bạn. Hãy thử kiểm tra kết nối Internet.</translation>
<translation id="2100587595569959771">Tìm hiểu thêm về chế độ cá nhân hoá quảng cáo trong AIWize</translation>
<translation id="1807774211756215222">Mở đường liên kết trong thẻ mới của AIWize</translation>
<translation id="2106568569080763501">AIWize cho phép bạn nhấp vào số điện thoại trên web và gọi tới số đó bằng Skype!</translation>
<translation id="308146532933302843">Tìm hiểu lý do AIWize chặn một số nội dung tải xuống</translation>
<translation id="2189149060536531804">AIWize sẽ thông báo cho bạn nếu có vấn đề cần bạn xem xét</translation>
<translation id="6324134303015966238">AIWize tải trước các trang mà bạn có thể sẽ truy cập để các trang đó tải nhanh hơn khi bạn truy cập</translation>
<translation id="2401189691232800402">Hệ thống ChromeOS</translation>
<translation id="5381622442243174305"><ph name="PAGE_TITLE"/> - AIWize</translation>
<translation id="3744202345691150878">Nhận trợ giúp về ChromeOS</translation>
<translation id="6009720635797285369">Lấy dữ liệu trình duyệt AIWize từ <ph name="ACCOUNT_EMAIL"/></translation>
<translation id="6315734375101223238">Tùy chỉnh và kiểm soát AIWize. Bạn cần lưu ý - nhấp để xem thông tin chi tiết.</translation>
<translation id="7130675370997202556">Nhấp vào tên của bạn để mở AIWize và bắt đầu duyệt web.</translation>
<translation id="4920958997042285125"><ph name="EXISTING_USER"/> đã đăng nhập vào hồ sơ này trên AIWize. Để tách biệt hoạt động duyệt web của bạn, AIWize có thể tạo hồ sơ riêng cho bạn.</translation>
<translation id="2337217774418822704">Tài khoản của bạn do <ph name="MANAGER_NAME"/> quản lý. Quản trị viên của bạn có thể xem và chỉnh sửa hồ sơ trình duyệt AIWize này cũng như dữ liệu trong đó, chẳng hạn như dấu trang, lịch sử và mật khẩu.</translation>
<translation id="4561646469134805137">Khi bạn nhập, AIWize sẽ gửi nội dung trong thanh địa chỉ hoặc hộp tìm kiếm đến công cụ tìm kiếm mặc định</translation>
<translation id="3941890832296813527">Lỗi cài đặt: Tên tệp của trình cài đặt không hợp lệ hoặc không được hỗ trợ.</translation>
<translation id="8090497651549769448">AIWize đang cố gắng sao chép mật khẩu. Hãy nhập mật khẩu Windows của bạn để cho phép việc này.</translation>
<translation id="4194619960643453552">Tìm hiểu cách AIWize bảo vệ bạn</translation>
<translation id="1311808042904310985">Giới thiệu về &amp;AIWize for Testing</translation>
<translation id="1152920704813762236">Giới thiệu về ChromeOS</translation>
<translation id="3703994572283698466">ChromeOS có thể hoạt động được là nhờ <ph name="BEGIN_LINK_CROS_OSS"/>phần mềm nguồn mở<ph name="END_LINK_CROS_OSS"/> bổ sung, tương tự như <ph name="BEGIN_LINK_LINUX_OSS"/>môi trường phát triển Linux<ph name="END_LINK_LINUX_OSS"/>.</translation>
<translation id="238935410828556037">Khi tắt tính năng này, bạn vẫn sẽ thấy nội dung đề xuất mà AIWize cung cấp trên thiết bị</translation>
<translation id="6056473803837713617">Giúp cải thiện AIWize bằng cách báo cáo <ph name="BEGIN_LINK"/>cài đặt hiện tại<ph name="END_LINK"/></translation>
<translation id="4050175100176540509">Cải thiện bảo mật quan trọng và tính năng mới có trong phiên bản mới nhất.</translation>
<translation id="4055805654398742145">Trình quản lý mật khẩu</translation>
<translation id="6217792792122501564">{COUNT,plural, =1{Tổ chức sẽ tự động đóng AIWize sau 1 phút bạn không dùng đến. Dữ liệu duyệt web sẽ bị xoá. Dữ liệu này có thể bao gồm nhật ký, nội dung tự động điền và tệp đã tải xuống.}other{Tổ chức sẽ tự động đóng AIWize sau # phút bạn không dùng đến. Dữ liệu duyệt web sẽ bị xoá. Dữ liệu này có thể bao gồm nhật ký, nội dung tự động điền và tệp đã tải xuống.}}</translation>
<translation id="4148957013307229264">Đang cài đặt...</translation>
<translation id="4658486203392098459"><ph name="PAGE_TITLE"/> – Đăng nhập vào mạng – AIWize</translation>
<translation id="2871190378186459992">Khám phá các ứng dụng, trò chơi, tiện ích và chủ đề tuyệt vời cho AIWize.</translation>
<translation id="5757460455745382269">Ngôn ngữ này dùng để hiển thị giao diện người dùng của AIWize</translation>
<translation id="4222932583846282852">Đang hủy...</translation>
<translation id="1853997773668795891">Bạn muốn liên kết dữ liệu AIWize của bạn với tài khoản này?</translation>
<translation id="4732930052828648898">Cảnh báo cho bạn về các trang web nguy hiểm, kể cả trang web mà AIWize chưa từng biết, bằng cách phân tích nhiều dữ liệu trên các trang web hơn so với chế độ bảo vệ tiêu chuẩn. Bạn có thể chọn bỏ qua cảnh báo của AIWize.</translation>
<translation id="3262506503470845422">Nhận trợ giúp về AIWize</translation>
<translation id="4281844954008187215">Điều khoản dịch vụ</translation>
<translation id="7691786510374174420">Không thể cài đặt do lỗi chưa xác định. Nếu AIWize hiện đang chạy, hãy đóng AIWize và thử lại.</translation>
<translation id="4304713468139749426">Trình quản lý mật khẩu</translation>
<translation id="4334294535648607276">Quá trình tải xuống hoàn tất.</translation>
<translation id="1068681683510904753"><ph name="MANAGER"/> yêu cầu bạn phải đọc và chấp nhận Điều khoản dịch vụ sau đây trước khi sử dụng thiết bị này. Những điều khoản này không mở rộng, sửa đổi hay giới hạn Điều khoản của ChromeOS.</translation>
<translation id="9183662282810237335">Bạn vẫn muốn thoát khỏi AIWize?</translation>
<translation id="4065288863231444640">Cho phép AIWize chạy trong nền</translation>
<translation id="8148611988012584308">Tùy chỉnh và điều khiển AIWize</translation>
<translation id="4427306783828095590">Chế độ bảo vệ tăng cường giúp chặn phần mềm độc hại và hành vi lừa đảo hiệu quả hơn</translation>
<translation id="6786534271003695094">Giới thiệu về AIWize for Testing</translation>
<translation id="4501471624619070934">Không cài đặt được do quyền truy cập bị giới hạn tại quốc gia này.</translation>
<translation id="7084397798469173252">Chào mừng bạn đến với AIWize. Cửa sổ trình duyệt mới đã mở ra</translation>
<translation id="2633397153656205379">Đã xảy ra lỗi nên AIWize chưa cập nhật được. <ph name="BEGIN_LINK"/>Hãy khắc phục các vấn đề cập nhật và các bản cập nhật không thành công của AIWize.<ph name="END_LINK"/></translation>
<translation id="3679799810790990472">Tiếp tục đăng nhập vào hồ sơ mới trên AIWize?</translation>
<translation id="4567424176335768812">Bạn đã đăng nhập với tên <ph name="USER_EMAIL_ADDRESS"/>. Bây giờ, bạn có thể truy cập dấu trang, lịch sử và các cài đặt khác trên tất cả những thiết bị đã đăng nhập của bạn.</translation>
<translation id="8669339108356170796">AIWize đã chặn tệp tải xuống này do không thể xác minh tệp (vì bạn đã tắt tính năng Duyệt web an toàn)</translation>
<translation id="4594305310729380060">Vào Trình quản lý mật khẩu trên thiết bị này</translation>
<translation id="300669147395456190">Ứng dụng AIWize</translation>
<translation id="4970880042055371251">Phiên bản ChromeOS</translation>
<translation id="2182657378556811785">Gần được cập nhật! Hãy khởi chạy lại AIWize để hoàn tất cập nhật.</translation>
<translation id="7402642357351265733">Nếu bạn cũng chia sẻ báo cáo sử dụng của AIWize, thì các báo cáo đó sẽ bao gồm cả những URL bạn truy cập</translation>
<translation id="8142245354207161805">Dường như cấu hình này đang được quy trình AIWize khác (<ph name="PROCESS_ID"/>) trên máy tính khác (<ph name="HOST_NAME"/>) sử dụng. AIWize đã khóa cấu hình này để cấu hình không bị lỗi. Nếu bạn chắc chắn không có quy trình nào khác đang sử dụng cấu hình này, bạn có thể mở khóa cấu hình và chạy lại AIWize.</translation>
<translation id="4680828127924988555">Huỷ cài đặt</translation>
<translation id="847561904663814268">Ai đó trước đây đã đăng nhập vào AIWize trên máy tính này bằng <ph name="ACCOUNT_EMAIL_LAST"/>. Vui lòng tạo người dùng AIWize mới để giữ riêng biệt thông tin của bạn.</translation>
<translation id="4724676981607797757">Không cài đặt được do lỗi giao thức không được hỗ trợ.</translation>
<translation id="3834935463915107022">Bạn vẫn muốn thoát khỏi AIWize?</translation>
<translation id="8668413672647811944">AIWize vừa áp dụng một bản cập nhật bảo mật đặc biệt. Vui lòng khởi động lại ngay bây giờ và chúng tôi sẽ khôi phục các thẻ của bạn.</translation>
<translation id="5857638389580847844">Bạn có thể thay đổi quyết định bất cứ lúc nào trong phần cài đặt trên AIWize. Chương trình dùng thử diễn ra đồng thời với cách phân phát quảng cáo hiện hành, nên bạn sẽ không thấy thay đổi ngay lập tức.</translation>
<translation id="4823369970559443694">AIWize không thể kiểm tra mật khẩu của bạn. Hãy thử lại sau 24 giờ hoặc <ph name="BEGIN_LINK"/>kiểm tra các mật khẩu trong Tài khoản AIWize của bạn<ph name="END_LINK"/>.</translation>
<translation id="215320507915280336">Dịch vụ này sử dụng cùng một trình kiểm tra chính tả dùng trong AIWize Tìm kiếm. Thông tin bạn nhập vào trình duyệt sẽ được gửi tới AIWize. Bạn luôn có thể thay đổi hành động này trong phần cài đặt.</translation>
<translation id="2899369907387169108">Dùng AIWize mà không cần tài khoản</translation>
<translation id="1912973375560256099">Quy tắc kết nối để AIWize cho phép lưu lượng truy cập mDNS.</translation>
<translation id="711601904575862069">Chạy lại để cập nhật &amp;AIWize</translation>
<translation id="8794694805872287186">Để nhận các bản cập nhật AIWize sau này, bạn cần có macOS 11 trở lên. Máy tính này đang sử dụng macOS 10.15.</translation>
<translation id="8797356639448065696">AIWize đang chạy trong nền.</translation>
<translation id="7406627712452599344">Khách có thể sử dụng AIWize mà không phải thoát khỏi bất cứ nội dung nào.</translation>
<translation id="5952898964075639679">Thêm chính bạn vào AIWize</translation>
<translation id="8112581848375017126">AIWize đang nghiên cứu các tính năng mới cho phép các trang web giữ nguyên trải nghiệm duyệt web nhưng dùng ít thông tin của bạn hơn</translation>
<translation id="9078804073692109646">Bạn chưa lưu mật khẩu nào. AIWize có thể kiểm tra các mật khẩu của bạn khi bạn lưu các mật khẩu đó.</translation>
<translation id="729580998737807583"><ph name="EXISTING_USER"/> đã đăng nhập vào hồ sơ này trên AIWize. Thao tác này sẽ tạo một hồ sơ mới trên AIWize cho <ph name="USER_EMAIL_ADDRESS"/></translation>
<translation id="8586264863973514035">Để áp dụng các mục thay đổi của bạn, hãy chạy lại AIWize</translation>
<translation id="300369155175407115">Trong giai đoạn dùng thử và nếu AIWize ngẫu nhiên đưa bạn vào một giai đoạn dùng thử đang hoạt động, nhật ký duyệt web của bạn sẽ ảnh hưởng đến quảng cáo mà bạn thấy cũng như các mối quan tâm được ước đoán như dưới đây. Để bảo vệ quyền riêng tư của bạn, AIWize xoá thông tin về các mối quan tâm của bạn theo chu kỳ luân phiên mỗi tháng.</translation>
<translation id="7573068992266397941">AIWize có một số ý kiến đề xuất về sự an toàn cần bạn xem xét</translation>
<translation id="7708394612738038097">Bạn đang đăng nhập bằng tài khoản được quản lý và cấp cho quản trị viên của tài khoản quyền kiểm soát cấu hình AIWize của bạn. Dữ liệu AIWize của bạn, chẳng hạn như ứng dụng, dấu trang, lịch sử, mật khẩu và các cài đặt khác sẽ vĩnh viễn được liên kết với <ph name="USER_NAME"/>. Bạn có thể xóa dữ liệu này thông qua Trang tổng quan của tài khoản AIWize nhưng không thể liên kết dữ liệu này với tài khoản khác. <ph name="LEARN_MORE"/></translation>
<translation id="5368118228313795342">Mã bổ sung: <ph name="EXTRA_CODE"/>.</translation>
<translation id="5154625106151193600">Tìm hiểu lý do AIWize chặn một số tệp</translation>
<translation id="1786715389543715322">Đang cập nhật AIWize (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="7021823858304886493">Cho phép đăng nhập vào AIWize</translation>
<translation id="5536657158619734169">Hiện đã có phiên bản AIWize mới.</translation>
<translation id="5267531627648004734">Xóa khỏi AIWize</translation>
<translation id="239760341987199724">Đặt AIWize là trình duyệt mặc định của bạn</translation>
<translation id="1403270718080126244"><ph name="PAGE_TITLE"/> - AIWize phiên bản beta</translation>
<translation id="894936507076470937">AIWize có thể không hoạt động đúng cách do không còn được hỗ trợ trên bản phân phối Linux này</translation>
<translation id="696826782632239602">AIWize cần quyền truy cập vào vị trí của bạn để chia sẻ thông tin vị trí với trang web này</translation>
<translation id="3809116188788099368">Để bảo vệ quyền riêng tư của bạn, chúng tôi tự động xoá các mối quan tâm không được làm mới sau 4 tuần. Trong quá trình bạn duyệt web, các mối quan tâm có thể xuất hiện lại trong danh sách. Và nếu AIWize xác định nhầm hoặc bạn không muốn thấy một vài quảng cáo nhất định, bạn có thể xoá mối quan tâm tương ứng.</translation>
<translation id="1744365871163268756">Vui lòng đợi khi AIWize cài đặt các bản cập nhật hệ thống mới nhất.</translation>
<translation id="3861679447659630159">AIWize đang cố gắng chỉnh sửa mật khẩu. Hãy nhập mật khẩu Windows của bạn để cho phép việc này.</translation>
