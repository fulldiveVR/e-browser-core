<translation id="7731184591599776500">የAIWize Enterprise ዓርማ</translation>
<translation id="8986207147630327271">የስራ መገለጫን ወደዚህ አሳሽ እያከሉ እና ለአስተዳዳሪዎ በስራ መገለጫው ላይ ብቻ ቁጥጥር እየሰጡ ነው።</translation>
<translation id="82609232232243542">AIWize ውስጥ ይግቡ</translation>
<translation id="3273774796888928550">ወደ AIWize በመለያ ይግቡ። ወደ መለያ አንድ ጊዜ ብቻ መግባት ከፈለጉ <ph name="GUEST_LINK_BEGIN"/>መሣሪያውን እንደ እንግዳ መጠቀም<ph name="GUEST_LINK_END"/> ይችላሉ።</translation>
<translation id="4561046754724442504">AIWize በራስ-ሰር ተዘግቷል</translation>
<translation id="5173820533850252773">AIWize ጊዜው አልፎበታል</translation>
<translation id="310518206836658214">{0,plural, =1{AIWize በአንድ ሰዓት ውስጥ ዳግም ይጀምራል}one{AIWize በ# ሰዓቶች ውስጥ ዳግም ይጀምራል}other{AIWize በ# ሰዓቶች ውስጥ ዳግም ይጀምራል}}</translation>
<translation id="5190991181158966940">የወደፊት የAIWize ዝማኔዎችን ለማግኘት Windows 10 ወይም ከዚያ በላይ ያስፈልግዎታል። ይህ ኮምፒውተር Windows 8.1ን እየተጠቀመ ነው።</translation>
<translation id="7863882214613921971">አገናኙን በAIWize አዲስ &amp;ትር ውስጥ ክፈት</translation>
<translation id="911206726377975832">የአሰሳ ውሂብዎም ይሰረዝ?</translation>
<translation id="5708733457516068434">በሙከራዎቹ ጊዜ ማስታወቂያዎችን ለእርስዎ ለማሳየት የሚጠቀሙባቸውን የዝንባሌ ጣቢያዎች ርዕሶች ማየት እና ማስወገድ ይችላሉ። AIWize በቅርብ ጊዜ የአሰሳ ታሪክዎ ላይ ተመስርቶ የእርስዎን ፍላጎቶች ይገምታል።</translation>
<translation id="2444257125841652328">የእርስዎ የስርዓት አስተዳዳሪ <ph name="TARGET_URL_HOSTNAME"/>ን ለመድረስ AIWize ተለዋጭ አሳሽን እንዲከፍት አዋቅረውታል።</translation>
