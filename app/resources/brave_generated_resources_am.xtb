<translation id="5565355416171743213">ማመሳሰል መጠቀም ይጀምሩ</translation>
<translation id="4332558599726753990">ማዋቀርን አመሳስል</translation>
<translation id="2187778349654214731">ለመጀመር ለማመሳሰል ባቀዱት ሁሉም መሳሪያዎች ላይ ብራቨ መጫን ያስፈልግዎታል። ከዚያ ደህንነቱ በተጠበቀ ሁኔታ ከማመሳሰል ኮድ ጋር ያገናኙዋቸው።</translation>
<translation id="7530575064080939974">የተመሳሰሉ መሣሪያዎችዎን ያቀናብሩ</translation>
<translation id="8668872235103666008">በመሳሪያዎችዎ ላይ AI Wizeን ማመሳሰል አልተቻለም</translation>
<translation id="7575156386943878014">አስምር አስተዳዳሪ</translation>
<translation id="1755198127524719638">የሲንክ ቅንብር</translation>
<translation id="7558480201297099157">በመሣሪያዎች መካከል ምን ዓይነት መረጃ ማመሳሰል እንደሚፈልጉ ወስነው ያቀናብሩ፤ እነዚህ ቅንብሮች በዚህ መሣሪያ ላይ ብቻ ተጽዕኖ ይኖራቸዋል።</translation>
<translation id="7731928563672901833">የመሣሪያ ዝርዝር</translation>
<translation id="28332161031213248">ከዚህ በታች ያለው የመሳሪያዎች ዝርዝር ሁሉንም በሲንክ ሰንሰለት ውስጥ ያሉ መሳሪያዎችን ያካትታል። እያንዳንዱ መሳሪያ ሌላኛውን በመጠቀም ሊተዳደር ይችላል።</translation>
<translation id="1313162974556054106">የመሣሪያ ስም</translation>
<translation id="923757506389336140"><ph name="DEVICE_NAME"/> (ይህ መሣሪያ)</translation>
<translation id="3686835020221422649">የመጨረሻው ገባሪ</translation>
<translation id="2569646144216067185">የቃል ቆጠራ: <ph name="WORD_COUNT"/></translation>
<translation id="7885157704277298658">ተቀድቷል</translation>
<translation id="8802630444265810662">የማመሳሰያ ኮድዎን ለማስተላለፍ በተንቀሳቃሽ መሣሪያው የሚመረተው የ QR ኮድ</translation>
<translation id="6221331245829088299">የ QR ኮድን ማሳየት ላይ አንድ ስህተት ነበር ፣ እባክዎ ያድሱ እና እንደገና ይሞክሩ።</translation>
<translation id="298546024891487702">ለመጀመር፣ በሁሉም ሲንክ ለማድረግ የሚያቅዱት መሳሪያዎች ላይ AI Wize ሊጫን ያስፈልጋል። አንድ ላይ ለማስተሳሰር፣ ደህንነቱ አስማማኝ የሆነ ሁሉንም መሳሪያዎች ለማስተሳሰር የሚጠቀሙበትን ሰንሰለት ያስጀምሩ።</translation>
<translation id="6200528822592747640">አዲስ የማመሳሰል ሰንሰለት ይጀምሩ</translation>
<translation id="5184726904895809379">አሁን ያለው የማመሳሰል ኮድ አለኝ</translation>
<translation id="8780295742023331191">የማመሳሰል ኮዱን ይመልከቱ</translation>
<translation id="9017050385815017931">ስልክ/ታብሌት</translation>
<translation id="1736420071277903564">ኮምፒውተር</translation>
<translation id="3407602902101449803">የሲንክ ሰንሰለት QR ኮድ</translation>
<translation id="8369686073965491869">በሞባይል ስልክዎ ላይ ወደ AI Wize Sync ይሂዱ እና ቁልፉ ላይ ጠቅ ያድርጉ</translation>
<translation id="6527776448555649991">“S ኮድ ” ን ሲንክ ማድረግ ይችላል</translation>
<translation id="1400862780574843709">ከዚህ በታች ያለውን QR ኮድ ስካን ለማድረግ ካሜራዎትን ይጠቀሙ።</translation>
<translation id="5086223971958279691">የሲንክ ሰንሰለት ኮድ</translation>
<translation id="2899261497479389619">ኢላማ በሆነው ኮምፒውተር ላይ፣ ቅንብር ውስጥ ወደ AI Wize Sync ይሂዱ እና ቁልፉን ጠቅ ያድርጉ።</translation>
<translation id="4827439149833241990">“፤ የሲንክ ኮድ እና#8221; አለኝ።</translation>
<translation id="8299617838343103908">ከዚህ በታች የሚታየውን የ አስምር ሰንሰለት ኮድ ቃላትን ያስገቡ።</translation>
<translation id="4485276108749547761">ይህን ኮድ እንደ ይለፍ ቃል ይያዙት። አንድ ሰው ከደረሰበት፣ የተመሳሰለ ውሂብዎን ሊያነብ እና ሊያሻሽል ይችላል።</translation>
<translation id="3034163433136515805">QR ኮድን ይመልከቱ</translation>
<translation id="5373825572723282843">የማመሳሰያ ኮዱን ያስገቡ</translation>
<translation id="1265244359514651398">የማመሳሰል ሰንሰለት የይለፍ ሀረግዎን ከዚህ በታች ያስገቡ።</translation>
<translation id="1061533051865606843">አዲስ መሳሪያ ይጨምሩ</translation>
<translation id="5093410893656857925">የመሳሪያውን አይነት ይምረጡ</translation>
<translation id="4581190919849683048">ከየትኛው መሣሪያ ጋር ማመሳሰል ይፈልጋሉ?</translation>
<translation id="4112587618563511470">ልክ ያልሆነ የማመሳሰል ኮድ ፣ እባክዎ ያረጋግጡ እና እንደገና ይሞክሩ።</translation>
<translation id="3995714999835224798">ይህ ኮድ ትክክለኛ አይደለም</translation>
<translation id="4432071071853308688">ይህ ኮድ ባዶ ነው</translation>
<translation id="955848693465029904">የውስጥ ማመሳሰል ማዋቀር ስህተት</translation>
<translation id="7456398316301207582">የውስጥ መለያ መሰረዝ ስህተት</translation>
<translation id="859506441384380749">ይህ ኮድ የተፈጠረው ከአገልግሎት ውጭ በሆነው የ AI Wize ስሪት ነው፣ እባክዎ መጀመሪያ ሌላው መሳሪያዎን ያሻሽሉ።</translation>
<translation id="3132642509209154999">ይህ ኮድ ጊዜው አልፎበታል። እባክዎ በሌላኛው መሳሪያዎ ላይ አዲስ በማመንጨት እንደገና ሞክሩ።</translation>
<translation id="2859229680945501779">ይህ ኮድ ልክ ያልሆነ ነው። እባክዎ ሰዓቱ እና የሰዓት ዞን በመሳሪያዎ ላይ በትክክል መዘጋጀታቸውን ያረጋግጡ።</translation>
<translation id="2339730291919608488">ከማመሳሰል ሰንሰለት ይውጡ</translation>
<translation id="115699408012835975">ማመሳሰልን ዳግም ካቀናበሩ እሱን ለማመሳሰል ከሌላ መሣሪያ ላይ የአስምር ኮድ ድጋሚ ማስገባት ይኖርብዎታል። እርግጠኛ ነዎት ለመቀጠል ይፈልጋሉ?</translation>
<translation id="6092564993102418148">እርግጠኛ ነዎት የተመረጠውን መሳሪያ ከማመሳሰል ሰንሰለት ላይ ማስወገድ ይፈልጋሉ?</translation>
<translation id="4400414577602898435">ማስጠንቀቂያ፦ ይህ የእርስዎን የAI Wize ውሂብ፣ የይለፍ ቃሎችዎን ጨምሮ እነዚህን የኮድ ቃላቶች ለፈጠረው መሳሪያ ያጋራል። እባክዎ እነዚህ የኮድ ቃላቶች እርስዎ በያዙት መሳሪያ የተፈጠሩ መሆናቸውን ደግመው ያረጋግጡ። 

እርግጠኛ ነዎት ይህን ማድረግ ይፈልጋሉ?</translation>
<translation id="7443185843787879670">AI Wize የስርዓተ ክወናህን ደህንነቱ የተጠበቀ ማከማቻ መድረስ አልቻለም። እንደ የይለፍ ቃሎች እና ኩኪዎች ያሉ መረጃዎችን ለመጠበቅ የሚያገለግለው ይህ ነው። የአሳሽዎን መገለጫ በመሳሪያዎች መካከል ለማገናኘት ለ AI Wize Sync እንዲሁ ያስፈልጋል። ይህ ማለት AI Wize Sync እየሰራ አይደለም ማለት ነው። ይህንን ችግር ለመፍታት፣ እባክዎን <ph name="BEGIN_LINK_SYNC_GUIDE"/>የAI Wize Sync መላ ፍለጋ መመሪያን ይመልከቱ<ph name="END_LINK_SYNC_GUIDE"/></translation>
<translation id="6802736947576520626">የማመሳሰል ምስጠራ ቁልፉ መጀመሪያ AI Wize Syncን ሲያዘጋጁ ከተጠቀሙበት የተለየ ይመስላል። እዚህ በጣም ቀላሉ ጥገና ከሌሎች የተመሳሰሉ መሳሪያዎችዎ የአንዱን የይለፍ ሀረግ ተጠቅመው የማመሳሰል ሰንሰለቱን እንደገና ማቀናበርና መቀላቀል ነው።</translation>
<translation id="4889767840132638381">የማመሳሰል ሰንሰለትን ዳግም ያስጀምሩ እና እንደገና ይቀላቀሉ</translation>
<translation id="1680065323266179640">የማመሳሰል መለያን ሰርዝ</translation>
<translation id="9064376100690171155">መለያውን እስከመጨረሻው ሰርዝ</translation>
<translation id="228906529296554286">መለያዎን መሰረዝ የተመሰጠረውን ውሂብዎን ከ AI Wize አገልጋዮች ያስወግዳል እና በሁሉም የተገናኙ መሳሪያዎችህ ላይ ማመሳሰልን ያሰናክላል።</translation>
<translation id="7578652532113583362">ግን በእነዚያ መሳሪያዎች ላይ በአካባቢው የተከማቸውን ውሂብ አይሰርዝም።</translation>
<translation id="2516405584294312544">ይህ ስረዛ ዘላቂ ሲሆን ውሂቡን መልሶ ለማግኘት ምንም መንገድ የለም። ማመሳሰልን እንደገና ለመጠቀም ከወሰኑ አዲስ መለያ መፍጠርና እያንዳንዱን መሳሪያ አንድ በአንድ እንደገና ማከል ያስፈልግዎታል።</translation>
<translation id="4860996720371753023">መለያ ስረዛ በሂደት ላይ ነው...</translation>
<translation id="4094590686212463338">ይህን የማመሳሰል ሰንሰለት መቀላቀል አልተቻለም። የማመሳሰል ሰንሰለት ተሰርዟል።</translation>
<translation id="4908081302669157000">የስልክ ቁጥሮች፣ ኢሜይሎች እና አድራሻዎች</translation>
<translation id="294985549514492876">የድር መተግበሪያዎች (PWAs)</translation>
<translation id="7029809446516969842">የይለፍ ቃላት</translation>
<translation id="6285118765755298263">ማውጫ ሌላ የፍለጋ ፕሮግራሞች</translation>
<translation id="919715748352669592">የ OpenSearch ዝርዝርን የሚከተሉ ድር ጣቢያዎችን በራስ-ሰር ይጠቁማል።</translation>
<translation id="6864914031231797928">ለቅጥያዎች የ Google በመለያ መግቢያዎችን ፍቀድ</translation>
<translation id="7878791177459550035">የሚዲያ ራውተር በአሳሽ ውስጥ የcast ባህሪ እንዲሰራ ያደርጋል።</translation>
<translation id="2707635989000984973">የማይቆሙ ጎራዎች የጎራ ስሞችን መፍታት</translation>
<translation id="1807158022157096592"><ph name="BEGIN_LINK"/>ስለ<ph name="END_LINK"/> የማይቆሙ ጎራዎች የግላዊነት ጥበቃዎች ተጨማሪ መረጃን ያግኙ።</translation>
<translation id="641308776160806829">የ Ethereum Name Service (ENS) የጎራ ስሞችን መፍታት</translation>
<translation id="6421218422395686663">ENS ን ከሰንሰለት ውጪ መፈለግን ይፍቀዱ።</translation>
