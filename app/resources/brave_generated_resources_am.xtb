<translation id="2896916411183256228">WebTorrent ን በመጠቀም በቀጥታ ቶረንቶችን ማሰሻ ላይ ያሳያል። ለቶረንት ፋይሎች እና ማግኔት ሊንኮች ድጋፍ ያደርጋል።</translation>
<translation id="5249433283143453448">በአሳሹ ውስጥ ያለ ጥበቃ የተደረገለት የቀጥታ ቪዲዮን እና ሌላ ይዘት ን ለመመልከት የ Widevine ዲጂታል መብቶች መተዳደሪያ (DRM) ክፍሉን ይጠቀሙ።</translation>
<translation id="1314131187310290315">Manifest V2 ቅጥያዎች</translation>
<translation id="2488433650767270565">የሚከተሉት ' Maniifest V2 ቅጥያዎች' ከChrome Web Store ይወገዳሉ፣ ነገር ግን አሁንም በ AI Wize ውስጥ ይደገፋሉ። ለማውረድ እና ለመጫን ወይም ለማጥፋት ቀይር።</translation>
<translation id="578671172657727816">NoScript™ ያብሩ</translation>
<translation id="9068475464170522036">NoScript በአንድ የተወሰነ ገጽ ላይ የሚሄዱ ወይም ለማሄድ የሚሞክሩ ግለሰባዊ ስክሪፕቶችን እንዲያግዱ እና እንዳይታገዱ የሚያስችልዎ 'Maniifest V2 ቅጥያ' ነው።</translation>
<translation id="1394592156621788100">uBlock Origin™ ያብሩ</translation>
<translation id="2638983091068889519">uBlock Origin ለላቁ ተጠቃሚዎች ብዙ አማራጮችን የያዘ ኃይለኛ የይዘት ማገድ መሳሪያዎችን የሚያቀርብ Manifest V2 ቅጥያ ነው።</translation>
<translation id="3909078036552544838">uMatrix™ ያብሩ</translation>
<translation id="8796148218203577506">uMatrix ብዙ ግላዊነትን የሚያጎላ መሳሪያዎች ያለው በነጥብ እና በጠቅ ማትሪክስ ላይ የተመሰረተ ፋየርዎልን የሚያቀርብ Manifest V2 ቅጥያ ነው።</translation>
<translation id="2385774023523989298">AdGuard™ ያብሩ</translation>
<translation id="188228077840632890">AdGuard የማስታወቂያ እገዳን፣ የወላጅ ቁጥጥር አማራጮችን እና ከሌሎች የ AdGuard አገልግሎት አቅርቦቶች ጋር እንዲዋሃድ የሚያደርግ የ Maniifest V2 ቅጥያ ነው።</translation>
