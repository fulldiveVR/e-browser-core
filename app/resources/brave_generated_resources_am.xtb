<translation id="970496996377628529">የሶስተኛ ወገን APIs ን በመጠቀም የያዙትን NFTs ወደ Wallet በራስ ሰር ያክሉ።</translation>
<translation id="4898839076551703154">በግል መስኮቶች ውስጥ የAI Wize የገንዘብ መያዣን ያንቁ።</translation>
<translation id="1550684990179058322">ማስጠንቀቂያ፦ በግላዊ መስኮት ክፍለጊዜ ውስጥ የገንዘብ ቦርሳ አድራሻን ዳግም መጠቀም አንድ ጣቢያን የግላዊ መስኮት ክፍለጊዜ ግላዊ ካልሆነ የመስኮት ክፍለጊዜ ጋር እንዲገናኝ ሊያስችል ይችላል።</translation>
