<translation id="3314921753580327793">አድራሻ ይተይቡ: ፖርት (በአንድ መስመር አንድ)</translation>
<translation id="3755189300481406891">ድልድይ ጠይቅ</translation>
<translation id="6924425739431382319">BridgeDBን በማነጋገር ላይ። እባክዎን ይጠብቁ።</translation>
<translation id="811745063252080651">ድልድይ ለመጠየቅ CAPTCHA ን ይፍቱ።</translation>
