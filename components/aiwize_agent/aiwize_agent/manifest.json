{
  "manifest_version": 3,
  "name": "WIZE Agent",
  "description": "Your second brain and hands for web browsing. A browser extension that solves your problems.",
  "version": "0.9",
  "action": {
    "default_icon": "icon.png",
    "default_title": "WIZE Agent"
  },
  "side_panel": {
    "default_path": "side_panel.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_end",
      "js": ["js/vendor.js", "js/contentScript.js"]
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "activeTab",
    "tabCapture",
    "alarms",
    "webNavigation",
    "windows",
    "sidePanel",
    "debugger"
  ],
  "host_permissions": ["<all_urls>"]
}
